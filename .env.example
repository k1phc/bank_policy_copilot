# --- LLM (OpenAI-compatible local server) ---
# Examples:
#   Ollama:   http://localhost:11434/v1
#   LM Studio: http://localhost:1234/v1
LLM_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# Chat model name as exposed by your local server.
# Ollama examples: llama3.1:8b, qwen2.5:7b, mistral:7b
LLM_MODEL=llama3.1:8b

# Embedding model and its output dimension (must match!).
# Ollama examples:
#   nomic-embed-text -> 768
#   bge-m3           -> 1024
#   mxbai-embed-large -> 1024
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# --- Vector store (Postgres + pgvector) ---
DATABASE_URL=postgresql://bank:bank@localhost:5432/bank_policy

# --- App paths ---
DOCS_PATH=sample_bank_docs
AUDIT_LOG_PATH=logs/audit_log.jsonl
